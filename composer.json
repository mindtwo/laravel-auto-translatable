{
    "name": "mindtwo/laravel-auto-translatable",
    "description": "AI-powered translation package for Laravel with smart markdown chunking and extensible adapters",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "mindtwo GmbH",
            "email": "info@mindtwo.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0",
        "laravel-lang/native-locale-names": "^2.5",
        "league/commonmark": "^2.5",
        "prism-php/prism": "^0.99.20||^0.100.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "chiiya/code-style-php": "^3.3",
        "larastan/larastan": "^3.0",
        "mindtwo/laravel-translatable": "^2.1",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpro/grumphp": "^2.0",
        "phpstan/phpstan": "^2.1",
        "spatie/laravel-translatable": "^6.11",
        "yethee/tiktoken": "^1.1"
    },
    "suggest": {
        "spatie/laravel-translatable": "For automatic JSON column translation storage",
        "yethee/tiktoken": "For accurate token counting with OpenAI models (gpt-3.5-turbo, gpt-4, etc)"
    },
    "autoload": {
        "psr-4": {
            "Mindtwo\\AutoTranslatable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mindtwo\\AutoTranslatable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mindtwo\\AutoTranslatable\\AutoTranslatableServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true,
            "phpro/grumphp": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "lint": [
            "vendor/bin/ecs check --fix",
            "vendor/bin/php-cs-fixer fix",
            "vendor/bin/rector process"
        ],
        "lint:check": [
            "vendor/bin/ecs check",
            "vendor/bin/php-cs-fixer fix --dry-run",
            "vendor/bin/rector process --dry-run"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
